pub type SomeType {
  ConstructorName
  OtherConstructor(Int, wibble: Float)
}

pub fn main(value: SomeType) -> #(SomeType, SomeType) {
  let value2 = OtherConstructor(10, wibble: 3.14)
  #(value, value2)
}


